# Quinx AI — Email Sender
# Copy this file to .env and fill in your values

# Hostinger SMTP / Webmail credentials
HOSTINGER_EMAIL=your_email@yourdomain.com
HOSTINGER_PASSWORD=your_password_here

# Path to the email output Excel file to send
LEADS_FILE=path/to/email_output.xlsx

# Browser mode for Playwright sender (true = no visible browser)
HEADLESS=true

# Logging verbosity (debug | info | warn | error)
LOG_LEVEL=info
